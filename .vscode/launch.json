{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Mozzy (Development)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "toolArgs": [
        "--dart-define",
        "GOOGLE_WEB_CLIENT_ID=${env:GOOGLE_WEB_CLIENT_ID}",
        "--dart-define",
        "GEMINI_API_KEY=${env:GEMINI_API_KEY}",
        "--dart-define",
        "GEMINI_VISION_MODEL=gemini-3-flash-preview"
      ]
    },
    {
      "name": "Mozzy (Integration Test - Local News)",
      "request": "launch",
      "type": "dart",
      "program": "integration_test/local_news_e2e_test.dart",
      "toolArgs": [
        "--dart-define=MOZZY_INTEGRATION_TEST=true",
        "--dart-define=GOOGLE_WEB_CLIENT_ID=dummy_client_id_for_test",
        "--dart-define=GEMINI_API_KEY=dummy_key_for_test"
      ]
    },
    {
      "name": "Mozzy (Integration Test - Marketplace)",
      "request": "launch",
      "type": "dart",
      "program": "integration_test/marketplace_e2e_test.dart",
      "toolArgs": [
        "--dart-define=MOZZY_INTEGRATION_TEST=true",
        "--dart-define=GOOGLE_WEB_CLIENT_ID=dummy_client_id_for_test",
        "--dart-define=GEMINI_API_KEY=dummy_key_for_test"
      ]
    }
  ]
}
