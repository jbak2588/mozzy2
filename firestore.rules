rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // posts under countries/{country}/domains/local_news/posts/{postId}
    match /countries/{country}/domains/local_news/posts/{postId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.location != null
        && request.resource.data.geoPath is string;

      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if request.auth != null
          && (resource.data.isSecret == false || request.auth.uid in resource.data.visibleToUserIds);
        
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.postId == postId
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.isDeleted == false
          && request.resource.data.isSecret is bool
          && request.resource.data.postOwnerId is string
          && request.resource.data.visibleToUserIds is list
          && (request.auth.uid in request.resource.data.visibleToUserIds)
          && (request.resource.data.postOwnerId in request.resource.data.visibleToUserIds);
        
        allow update, delete: if request.auth != null
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.postId == resource.data.postId
          && request.resource.data.postOwnerId == resource.data.postOwnerId
          && request.resource.data.visibleToUserIds == resource.data.visibleToUserIds
          && request.resource.data.isSecret == resource.data.isSecret;
      }
    }
    
    // [헬퍼 함수]
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // [1] 사용자 프로필
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // [2] 국가별 도메인 게시글 (Path-sharded architecture)
    // 경로: countries/{countryId}/domains/{domainId}/posts/{postId}
    match /countries/{countryId}/domains/{domainId}/posts/{postId} {
      
      // 누구나 읽기 가능 (하위 로컬 정책에 따라 필터링될 수 있음)
      allow read: if isAuthenticated();
      
      // 작성 및 수정 규칙
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.geoPath.size() > 0
        && request.resource.data.trustScore >= 0.0;
        
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId; // 작성자 변경 금지
        
      allow delete: if isOwner(resource.data.userId);
    }

    // [Marketplace Products]
    // 경로: countries/{country}/domains/marketplace/products/{productId}
    match /countries/{country}/domains/marketplace/products/{productId} {
      allow read: if isAuthenticated() && resource.data.isDeleted == false;

      allow create: if isAuthenticated()
        && request.resource.data.sellerId == request.auth.uid
        && request.resource.data.title is string && request.resource.data.title.size() > 0
        && (request.resource.data.price is int || request.resource.data.price is number)
        && request.resource.data.price >= 0
        && request.resource.data.countryCode is string
        && request.resource.data.geoPath is string
        && request.resource.data.isDeleted == false;

      allow update: if isAuthenticated()
        && resource.data.sellerId == request.auth.uid
        && request.resource.data.sellerId == resource.data.sellerId; // immutable sellerId

      allow delete: if isAuthenticated() && resource.data.sellerId == request.auth.uid;

      match /likes/{userId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.auth.uid == userId
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.productId == productId;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
        allow update: if false;
      }
    }

    // [3] 채팅 (추후 확장 예정)
    match /chat_rooms/{roomId} {
      allow read, write: if isAuthenticated() 
        && request.auth.uid in resource.data.participants;
    }
    
    // [Collection Group] 모든 도메인의 'posts' 컬렉션에 공통 적용
    match /{path=**}/posts/{postId} {
      allow read: if isAuthenticated();
    }
  }
}
